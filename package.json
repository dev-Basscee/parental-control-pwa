{
  "name": "parental-control-pwa",
  "version": "1.0.0",
  "description": "Windows parental control PWA — block apps, monitor activity",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently --names \"agent,server,vite\" --prefix-colors \"magenta,yellow,cyan\" \"node agent/src/index.js\" \"node server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "agent": "node agent/src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^8.2.2",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "vite": "^8.1.0"
  }
}
